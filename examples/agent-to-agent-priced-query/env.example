# ─── Agent-to-Agent Priced Query — example environment ──────────────────
# Rename this file to `.env` and fill in locally. `.env` is .gitignore'd
# at package and example level; real keys MUST NOT be committed.
#
# NOTE: shipped as `env.example` (no leading dot) because the sandbox
# blocks writes to dotfiles ending `.env*`. Rename to `.env.example`
# when checking in, or use this file directly — both scripts read from
# `./env.example` if `./.env` does not exist (see shared.ts loader).

# Safety flag. Leave `false` for the reference flow. Flipping this to
# `true` requires I_UNDERSTAND_THIS_WILL_SPEND_REAL_USDC=1 in the same
# environment; both scripts fail loudly otherwise.
MAINNET=false
I_UNDERSTAND_THIS_WILL_SPEND_REAL_USDC=0

# Canonical AlterRouter (Base mainnet) — post-keccak-fix redeploy.
# Source: .claude/memory/infra-alter-router-broadcasts.md.
ALTER_ROUTER_ADDRESS=0x8c78c8a2c12f18001170530650ccab4b76dc1e13

# Production default. For local dev, override with http://localhost:9402/facilitator.
FACILITATOR_URL=https://x402.org/facilitator

# Network — reference flow uses base-sepolia so nothing leaks if a
# future edit wires a real signer. Flip to `base` only with MAINNET=true
# and the confirmation flag set.
X402_NETWORK=base-sepolia
X402_ASSET=USDC

# Priced-query tier — $0.01 USDC (L2 agent-to-agent, per CLAUDE.md).
PRICED_QUERY_AMOUNT=0.01

# Handles. Both sides are Instrument-tier per D-ID8.
REQUESTER_HANDLE=~cc-opus-4-6
PROVIDER_HANDLE=~cc-sonnet-4-6

# Sovereign handle that Acts-By on the provider-side response (D-ID8).
PROVIDER_ACTED_BY=~blake

# Ed25519 private key paths (hex, 32 bytes). DO NOT COMMIT.
# Generate ephemeral test keys with:
#   node -e "console.log(require('@noble/hashes/utils').bytesToHex(require('@noble/hashes/utils').randomBytes(32)))"
REQUESTER_PRIVATE_KEY_PATH=./requester.key
PROVIDER_PRIVATE_KEY_PATH=./provider.key

# Local provenance log written by requester.ts after verifying the
# signed receipt. One JSON line per settled query.
PROVENANCE_LOG_PATH=./provenance-log.jsonl

# Receipt freshness window (seconds). Responses older than this are
# rejected as potential replays.
RECEIPT_MAX_AGE_SEC=120
